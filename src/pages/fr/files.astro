---
import Layout from "../../layouts/Layout.astro";
import { cryptidFiles } from "../../data/cryptidFiles";
import { getTranslatedCryptidFile } from "../../data/cryptidFilesTranslations";
import CryptidCard from "../../components/CryptidCard.astro";
import { Search, Filter } from "@lucide/astro";
import { getTranslations } from '../../i18n/utils';

const t = getTranslations('fr');

// Get unique regions for filter
const regions = ['all', ...Array.from(new Set(cryptidFiles.map(c => c.region)))];
const dangerLevels = ['all', 'Low', 'Medium', 'High', 'Unknown'];
---

<Layout>
  <div class="min-h-screen bg-[#0f0f0f] py-12">
    <div class="container mx-auto px-4">
      {/* Header */}
      <div class="mb-12 text-center">
        <div class="inline-block px-4 py-2 bg-lime-400/10 border border-lime-400 rounded-sm mb-4">
          <span class="text-lime-400 font-['Courier_New']">{t.files.classifiedDatabase}</span>
        </div>
        <h1 class="mb-4">{t.files.title}</h1>
        <p class="text-purple-200 max-w-2xl mx-auto">
          {t.files.description}
        </p>
      </div>

      {/* Search and Filters */}
      <div class="max-w-5xl mx-auto mb-12 space-y-4">
        {/* Search Bar */}
        <div class="relative">
          <Search class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-lime-400" />
          <input
            type="text"
            id="search-input"
            placeholder={t.files.searchPlaceholder}
            class="w-full pl-12 pr-4 py-4 bg-purple-950/50 border-2 border-purple-800 text-white placeholder-purple-400 focus:outline-none focus:border-lime-400 transition-colors font-['Courier_New']"
          />
        </div>

        {/* Filters */}
        <div class="flex flex-col md:flex-row gap-4 items-start md:items-center p-4 bg-purple-950/30 border border-purple-800">
          <div class="flex items-center gap-2">
            <Filter class="w-5 h-5 text-lime-400" />
            <span class="text-lime-400 font-['Courier_New']">{t.files.filters}</span>
          </div>

          <div class="flex flex-col md:flex-row gap-4 flex-1 min-w-0 w-full md:w-auto">
            <div class="flex items-center gap-2 w-full min-w-0">
              <label class="text-purple-300 font-['Courier_New'] whitespace-nowrap flex-shrink-0">{t.files.region}</label>
              <select
                id="filter-region"
                class="px-3 py-2 bg-black border border-purple-700 text-white focus:outline-none focus:border-lime-400 font-['Courier_New'] flex-1 min-w-0 max-w-full"
              >
                {regions.map(region => (
                  <option value={region}>
                    {region === 'all' ? t.files.allRegions : region}
                  </option>
                ))}
              </select>
            </div>

            <div class="flex items-center gap-2 w-full min-w-0">
              <label class="text-purple-300 font-['Courier_New'] whitespace-nowrap flex-shrink-0">{t.files.danger}</label>
              <select
                id="filter-danger"
                class="px-3 py-2 bg-black border border-purple-700 text-white focus:outline-none focus:border-lime-400 font-['Courier_New'] flex-1 min-w-0 max-w-full"
              >
                {dangerLevels.map(level => (
                  <option value={level}>
                    {level === 'all' ? t.files.allLevels : level}
                  </option>
                ))}
              </select>
            </div>
          </div>

          <div id="results-count" class="text-purple-300 font-['Courier_New'] whitespace-nowrap" data-files-found-text={t.files.filesFound}>
            {cryptidFiles.length} {t.files.filesFound}
          </div>
        </div>
      </div>

      {/* Results Grid */}
      <div id="results-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {cryptidFiles.map(cryptid => {
          const translatedCryptid = getTranslatedCryptidFile(cryptid, 'fr');
          return (
            <div 
              class="cryptid-card-wrapper" 
              data-name={translatedCryptid.name.toLowerCase()}
              data-codename={translatedCryptid.codename.toLowerCase()}
              data-region={translatedCryptid.region.toLowerCase()}
              data-danger={translatedCryptid.dangerLevel}
            >
              <CryptidCard cryptid={translatedCryptid} />
            </div>
          );
        })}
      </div>

      <div id="no-results" class="text-center py-16 hidden">
        <div class="text-purple-400 font-['Courier_New'] mb-4">
          {t.files.noFilesMatch}
        </div>
        <p class="text-purple-300">
          {t.files.tryAdjusting}
        </p>
      </div>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    const filterRegion = document.getElementById('filter-region') as HTMLSelectElement | null;
    const filterDanger = document.getElementById('filter-danger') as HTMLSelectElement | null;
    const resultsGrid = document.getElementById('results-grid') as HTMLElement | null;
    const resultsCount = document.getElementById('results-count') as HTMLElement | null;
    const noResults = document.getElementById('no-results') as HTMLElement | null;
    const cardWrappers = document.querySelectorAll('.cryptid-card-wrapper') as NodeListOf<HTMLElement>;

    if (!searchInput || !filterRegion || !filterDanger || !resultsGrid || !resultsCount || !noResults) {
      console.error('Required elements not found');
    } else {
      function filterCryptids() {
        if (!searchInput || !filterRegion || !filterDanger || !resultsGrid || !resultsCount || !noResults) return;
        
        const searchTerm = searchInput.value.toLowerCase();
        const selectedRegion = filterRegion.value;
        const selectedDanger = filterDanger.value;

        let visibleCount = 0;

        cardWrappers.forEach(wrapper => {
          const name = wrapper.dataset.name || '';
          const codename = wrapper.dataset.codename || '';
          const region = wrapper.dataset.region || '';
          const danger = wrapper.dataset.danger || '';

          const matchesSearch = !searchTerm || 
            name.includes(searchTerm) || 
            codename.includes(searchTerm) || 
            region.includes(searchTerm);
          
          const matchesRegion = selectedRegion === 'all' || region === selectedRegion.toLowerCase();
          const matchesDanger = selectedDanger === 'all' || danger === selectedDanger;

          if (matchesSearch && matchesRegion && matchesDanger) {
            wrapper.style.display = '';
            visibleCount++;
          } else {
            wrapper.style.display = 'none';
          }
        });

        // Update results count
        const filesFoundText = resultsCount.getAttribute('data-files-found-text') || 'DOSSIERS TROUVÉS';
        resultsCount.textContent = `${visibleCount} ${filesFoundText}`;

        // Show/hide no results message
        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
          resultsGrid.classList.add('hidden');
        } else {
          noResults.classList.add('hidden');
          resultsGrid.classList.remove('hidden');
        }
      }

      searchInput.addEventListener('input', filterCryptids);
      filterRegion.addEventListener('change', filterCryptids);
      filterDanger.addEventListener('change', filterCryptids);
    }
  </script>
</Layout>

