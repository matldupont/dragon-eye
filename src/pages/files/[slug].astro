---
import type { SanityDocument } from "@sanity/client";
import type { Image } from '@sanity/types';
import { loadQuery } from "../../../lib/load-query"

import FileDetails from "../../components/FileDetails.astro";
import Layout from "../../layouts/Layout.astro";
import { urlForImage } from "../../../lib/url-for-image";

interface CryptidFile extends SanityDocument {
  title: string;
  name: string;
  image: Image;
  imageAlt: string;
  description: string;
  caseNumber: string;
  alias?: string[];
  address?: string;
  knownAssociates?: string[];
  slug: {
    current: string;
  };
}

export async function getStaticPaths() {
  const { data: posts } = await loadQuery<CryptidFile[]>({
    query: `*[_type == "cryptidFile"]`,
  });

  return posts.map((post: CryptidFile) => {
    return {
      params: {
slug: post.slug.current,
      },
    };
  });
}

const { params } = Astro;

const { data } = await loadQuery<CryptidFile>({
  query: `*[_type == "cryptidFile" && slug.current == $slug][0]`,
  params,
});

const { title, name, image, imageAlt, description, caseNumber, alias, address, knownAssociates } = data;

const imageURL = urlForImage(image).url();

---
<Layout>
    <div class="flex flex-col gap-4 mt-8">
      <a href="/files" class="text-blue-500 hover:text-blue-600"
        >← Back to Files</a
      >
      <FileDetails
        image={imageURL}
        imageAlt={imageAlt}
        title={title}
        description={description}
        caseNumber={caseNumber}
        alias={alias}
        address={address}
        knownAssociates={knownAssociates}
        name={name}
      />
    </div>
  </Layout>
  