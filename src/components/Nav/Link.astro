---
interface Props {
  to?: string;
  href?: string;
  class?: string;
}

const { to, href, class: className } = Astro.props;
const linkHref = to || href || '#';
const currentPath = Astro.url.pathname;
const isActive = currentPath === linkHref || currentPath === `${linkHref}/`;
---

<a href={linkHref} class={className}>
  <slot />
</a>

