---
import type { CryptidFile } from '../data/cryptidFiles';
import { Image } from 'astro:assets';
import Link from './Nav/Link.astro';
import StatusBadge from './StatusBadge.astro';
import DangerBadge from './DangerBadge.astro';

interface Props {
  cryptid: CryptidFile & {
    id?: string;
    codename?: string;
    status?: 'Sighted' | 'Under Investigation' | 'Confirmed' | 'Myth';
    dangerLevel?: 'Low' | 'Medium' | 'High' | 'Unknown';
    region?: string;
    type?: string;
  };
  variant?: 'default' | 'compact';
}

const { cryptid, variant = 'default' } = Astro.props;
const fileUrl = `/files/${cryptid.slug}`;
---

{variant === 'compact' ? (
  <Link 
    to={fileUrl}
    class="block bg-purple-950/30 border-2 border-purple-800/50 p-3 hover:border-lime-400 transition-all hover:shadow-lg hover:shadow-lime-400/20 group"
  >
    <div class="flex gap-3">
      <div class="w-20 h-20 bg-black/50 border border-purple-700 flex-shrink-0 overflow-hidden">
        <Image 
          src={cryptid.image} 
          alt={cryptid.imageAlt}
          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
        />
      </div>
      <div class="flex-1 min-w-0">
        <div class="font-['Courier_New'] text-lime-400 mb-1">
          {cryptid.codename || cryptid.caseNumber}
        </div>
        <h3 class="font-medium truncate mb-1">{cryptid.name}</h3>
        <div class="text-purple-300">
          {cryptid.address || cryptid.region || 'Unknown'}
        </div>
      </div>
    </div>
  </Link>
) : (
  <Link 
    to={fileUrl}
    class="block bg-purple-950/30 border-2 border-purple-800/50 hover:border-lime-400 transition-all hover:shadow-lg hover:shadow-lime-400/20 group"
  >
    {/* Mugshot Area */}
    <div class="relative aspect-[4/3] bg-black/50 border-b-2 border-purple-700 overflow-hidden">
      <Image 
        src={cryptid.image} 
        alt={cryptid.imageAlt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
      {cryptid.status && (
        <div class="absolute top-2 left-2">
          <StatusBadge status={cryptid.status} />
        </div>
      )}
      <div class="absolute bottom-0 left-0 right-0 bg-black/80 p-2 font-['Courier_New'] text-lime-400">
        FILE: {cryptid.codename || cryptid.caseNumber}
      </div>
    </div>

    {/* Info Area */}
    <div class="p-4">
      <h3 class="font-medium mb-2">{cryptid.name}</h3>
      
      <div class="space-y-2 text-purple-300">
        {(cryptid.address || cryptid.region) && (
          <div class="flex items-center gap-2">
            <span class="text-lime-400 font-['Courier_New']">REGION:</span>
            <span>{cryptid.address || cryptid.region}</span>
          </div>
        )}
        {cryptid.type && (
          <div class="flex items-center gap-2">
            <span class="text-lime-400 font-['Courier_New']">TYPE:</span>
            <span>{cryptid.type}</span>
          </div>
        )}
      </div>

      {cryptid.dangerLevel && (
        <div class="mt-3 pt-3 border-t border-purple-800">
          <DangerBadge level={cryptid.dangerLevel} />
        </div>
      )}

      <div class="mt-4 w-full px-4 py-2 bg-lime-400 text-black hover:bg-yellow-400 transition-colors font-['Courier_New'] font-medium text-center">
        OPEN FILE →
      </div>
    </div>
  </Link>
)}
