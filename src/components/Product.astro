---
import { Image } from 'astro:assets';

interface ImageOption {
  src: any;
  alt: string;
}

const { emoji, title, description, price, imageOptions } = Astro.props;
const hasImageOptions = imageOptions && imageOptions.length > 0;

// Generate a unique ID for this product instance
const productId = `product-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="bg-purple-950/30 border-2 border-purple-800 p-6 flex flex-col h-full hover:border-yellow-400 transition-all" data-product-id={productId}>
  <div class="bg-black/50 border border-purple-700 h-48 rounded-sm mb-4 flex items-center justify-center relative overflow-hidden">
    {hasImageOptions ? (
      <>
        {imageOptions.map((image: ImageOption, index: number) => (
          <div data-image-option={index} class={`h-full w-full flex items-center justify-center ${index === 0 ? '' : 'hidden'}`}>
            <Image src={image.src} alt={image.alt} class="h-full object-contain p-2" />
          </div>
        ))}
        {imageOptions.length > 1 && (
          <div class="absolute bottom-2 right-2 flex space-x-2">
            {imageOptions.map((_: ImageOption, index: number) => (
              <button 
                class={`product-option-btn py-1 px-2 rounded-sm text-xs text-white font-['Courier_New'] ${index === 0 ? 'bg-yellow-400 text-black' : 'bg-purple-800 text-purple-200'}`}
                data-index={index}
                data-product-id={productId}
              >
                {index + 1}
              </button>
            ))}
          </div>
        )}
      </>
    ) : (
      <span class="text-9xl">{emoji}</span>
    )}
  </div>
  <h3 class="text-xl font-medium text-white mb-2">{title}</h3>
  <p class="mb-3 text-purple-200 text-sm leading-relaxed">{description}</p>
  <p class="font-bold text-lg mb-4 text-yellow-400 font-['Courier_New']">${price}</p>
  <button class="mt-auto w-full bg-yellow-400 text-black py-3 px-4 rounded-sm hover:bg-lime-400 transition-colors font-['Courier_New'] font-medium">
    ADD TO CART
  </button>
</div>

{hasImageOptions && imageOptions.length > 1 && (
  <script define:vars={{ productId }}>
    (function() {
      const productContainer = document.querySelector(`[data-product-id="${productId}"]`);
      if (!productContainer) return;

      const optionButtons = productContainer.querySelectorAll('.product-option-btn');
      
      optionButtons.forEach(button => {
        button.addEventListener('click', () => {
          const selectedIndex = Number(button.getAttribute('data-index'));
          const imageContainers = productContainer.querySelectorAll('[data-image-option]');
          
          // Hide all images and reset all buttons within this product only
          imageContainers.forEach((container, i) => {
            container.classList.toggle('hidden', i !== selectedIndex);
          });
          
          optionButtons.forEach((btn, i) => {
            if (i === selectedIndex) {
              btn.classList.remove('bg-purple-800', 'text-purple-200');
              btn.classList.add('bg-yellow-400', 'text-black');
            } else {
              btn.classList.remove('bg-yellow-400', 'text-black');
              btn.classList.add('bg-purple-800', 'text-purple-200');
            }
          });
        });
      });
    })();
  </script>
)}
