---
interface Props {
  status: 'Sighted' | 'Under Investigation' | 'Confirmed' | 'Myth';
}

const { status } = Astro.props;

const colors = {
  'Sighted': 'bg-lime-500/20 text-lime-400 border-lime-400',
  'Under Investigation': 'bg-yellow-500/20 text-yellow-400 border-yellow-400',
  'Confirmed': 'bg-red-500/20 text-red-400 border-red-400',
  'Myth': 'bg-gray-500/20 text-gray-400 border-gray-400'
};
---

<span class={`inline-flex items-center px-2 py-1 border rounded-sm font-['Courier_New'] ${colors[status]}`}>
  {status.toUpperCase()}
</span>
